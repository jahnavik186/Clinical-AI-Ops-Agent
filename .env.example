# Clinical AI Ops Agent — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the real .env to git

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ── Anthropic (replaces Amazon Bedrock for Python 3.14 compatibility) ────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── S3 ──────────────────────────────────────────────────────────────────────
DATA_BUCKET=clinical-ai-ops-data-123456789012-prod

# ── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE=clinical-ai-ops-agent-state-prod

# ── SNS ──────────────────────────────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:clinical-ai-ops-alerts-prod

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── SageMaker ────────────────────────────────────────────────────────────────
SAGEMAKER_PIPELINE_NAME=clinical-risk-model-pipeline-prod
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/clinical-ai-ops-sagemaker-role-prod
INSTANCE_TYPE=ml.m5.large

# ── Agent Config ──────────────────────────────────────────────────────────────
ENVIRONMENT=prod
MONITORED_ENDPOINTS=clinical-risk-model-v2
PSI_THRESHOLD_WARN=0.10
PSI_THRESHOLD_RETRAIN=0.20
PSI_THRESHOLD_CRITICAL=0.25
F1_SAFETY_THRESHOLD=0.80
PIPELINE_MAX_WAIT_SECONDS=3600
BLUE_GREEN_WAIT_SECONDS=300
